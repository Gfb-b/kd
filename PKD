TEACHER_NUM_LAYERS = teacher_model.num_layers - 1
TEACHER_HIDDEN_SIZE = teacher_model.hidden_size


class CodeBERTForPKD(torch.nn.Module):
    def __init__(self, model_path, teacher_num_layers, teacher_hidden_size, num_labels=NUM_LABELS):
        super().__init__()
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.base_model = AutoModel.from_pretrained(
            model_path,
            device_map="auto",
            torch_dtype=torch.float32,
            low_cpu_mem_usage=True
        )

        self.student_config = self.base_model.config
        self.student_num_layers = self.student_config.num_hidden_layers
        self.student_hidden_size = self.student_config.hidden_size
        self.teacher_num_layers = teacher_num_layers
        self.teacher_hidden_size = teacher_hidden_size
        self.num_labels = num_labels
        self.pkd_ignore_last = PKD_IGNORE_LAST_LAYER
        self.pkd_top_n = PKD_TOP_N_LAYERS

        assert 1 <= self.pkd_top_n <= self.student_num_layers
        self.layer_scale_e = self.teacher_num_layers / self.student_num_layers

        self.dropout = torch.nn.Dropout(0.1).to(self.device)
        self.classifier = torch.nn.Linear(self.student_hidden_size, num_labels).to(self.device, dtype=torch.float32)
        torch.nn.init.normal_(self.classifier.weight, std=0.02)
        if self.classifier.bias is not None:
            torch.nn.init.zeros_(self.classifier.bias)

        self.projection = None
        if self.student_hidden_size != self.teacher_hidden_size:
            self.projection = torch.nn.Linear(
                in_features=self.teacher_hidden_size,
                out_features=self.student_hidden_size
            ).to(self.device, dtype=torch.float32)

    def l2_normalize(self, x, eps=1e-8):
        return x / (torch.norm(x, dim=-1, keepdim=True) + eps)

    def get_layer_mapping(self):
        start_idx = self.student_num_layers - self.pkd_top_n
        student_top_layers = list(range(start_idx, self.student_num_layers))
        if self.pkd_ignore_last:
            student_top_layers = student_top_layers[:-1]

        layer_mapping = {}
        for s_k in student_top_layers:
            t_k = math.floor(self.layer_scale_e * s_k)
            t_k = max(0, min(t_k, self.teacher_num_layers - 1))
            layer_mapping[s_k] = t_k

        unique_mapping = {}
        used_t_layers = set()
        for s_k in sorted(layer_mapping.keys()):
            t_k = layer_mapping[s_k]
            if t_k not in used_t_layers:
                unique_mapping[s_k] = t_k
                used_t_layers.add(t_k)

        return unique_mapping

    def vanilla_kd_loss(self, student_logits, teacher_logits, T):
        student_soft = F.log_softmax(student_logits / T, dim=-1)
        teacher_soft = F.softmax(teacher_logits / T, dim=-1)
        kd_loss = F.kl_div(student_soft, teacher_soft, reduction="batchmean")
        return kd_loss

    def forward(self, student_input_ids, student_attention_mask=None, labels=None,
                teacher_input_ids=None, teacher_attention_mask=None):
        student_outputs = self.base_model(
            input_ids=student_input_ids,
            attention_mask=student_attention_mask,
            output_hidden_states=True,
            return_dict=True
        )
        all_hidden = student_outputs.hidden_states
        student_all_feat = torch.stack([h for h in all_hidden[1:]], dim=0)

        student_all_feat_cls = student_all_feat[:, :, 0, :]
        student_all_feat = self.l2_normalize(student_all_feat_cls)

        student_last_feat = all_hidden[-2]
        if student_attention_mask is not None:
            mask = student_attention_mask.unsqueeze(-1).expand(student_last_feat.size()).float()
            mask_sum = torch.clamp(mask.sum(dim=1), min=1e-4)
            pooled_output = torch.sum(student_last_feat * mask, dim=1) / mask_sum
        else:
            pooled_output = torch.mean(student_last_feat, dim=1)
        pooled_output = self.dropout(pooled_output)
        student_logits = self.classifier(pooled_output)

        loss = None
        if labels is not None:
            labels = labels.to(student_logits.device)
            if teacher_input_ids is None or teacher_attention_mask is None:
                cls_loss = F.cross_entropy(student_logits.view(-1, self.num_labels), labels.view(-1))
                loss = cls_loss
            else:
                teacher_all_feat, teacher_logits = teacher_model(
                    input_ids=teacher_input_ids,
                    attention_mask=teacher_attention_mask
                )
                teacher_all_feat = teacher_all_feat.to(self.device, dtype=torch.float32)
                teacher_logits = teacher_logits.to(self.device, dtype=torch.float32)

                if self.projection is not None:
                    teacher_all_feat = self.projection(teacher_all_feat)
                    teacher_all_feat = self.l2_normalize(teacher_all_feat)

                cls_loss = F.cross_entropy(student_logits.view(-1, self.num_labels), labels.view(-1))
                kd_loss = self.vanilla_kd_loss(student_logits, teacher_logits, PKD_T)
                layer_mapping = self.get_layer_mapping()
                layer_mse_loss = 0.0
                if len(layer_mapping) > 0:
                    for s_k, t_k in layer_mapping.items():
                        s_feat = student_all_feat[s_k]
                        t_feat = teacher_all_feat[t_k]
                        feat_diff = s_feat - t_feat
                        l2_norm_sq = torch.norm(feat_diff, p=2, dim=-1) ** 2
                        layer_mse_loss += l2_norm_sq.sum()

                loss = (1 - PKD_ALPHA) * cls_loss + PKD_ALPHA * kd_loss * PKD_T * PKD_T + PKD_BETA * layer_mse_loss

        return {"loss": loss, "logits": student_logits}


