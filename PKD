class StarCoderForPKD(torch.nn.Module):
    def __init__(self, base_model, num_labels=2):
        super().__init__()
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.base_model = base_model.to(self.device)
        self.config = base_model.config
        self.config.num_labels = num_labels
        self.hidden_size = self.config.hidden_size
        self.num_layers = self.config.num_hidden_layers

        self.classifier = torch.nn.Linear(self.hidden_size, num_labels).to(self.device, dtype=torch.float32)
        self.dropout = torch.nn.Dropout(0.1).to(self.device)
        torch.nn.init.normal_(self.classifier.weight, std=0.02)
        if self.classifier.bias is not None:
            torch.nn.init.zeros_(self.classifier.bias)

    def l2_normalize(self, x, eps=1e-8):
        return x / (torch.norm(x, dim=-1, keepdim=True) + eps)

    def forward(self, input_ids, attention_mask=None, **kwargs):
        with torch.no_grad():
            if input_ids is None:
                batch_size = 0 if attention_mask is None else attention_mask.shape[0]
                empty_feat = torch.zeros((self.num_layers - 1, batch_size, self.hidden_size), dtype=torch.float32).to(
                    self.device)
                empty_logits = torch.zeros((batch_size, NUM_LABELS), dtype=torch.float32).to(self.device)
                return empty_feat, empty_logits

            input_ids = input_ids.to(self.device)
            attention_mask = attention_mask.to(self.device) if attention_mask is not None else None

            outputs = self.base_model(
                input_ids=input_ids,
                attention_mask=attention_mask,
                output_hidden_states=True,
                return_dict=True,
                use_cache=False
            )
            all_hidden = outputs.hidden_states
            transformer_feat = torch.stack([h.float() for h in all_hidden[1:]], dim=0)

            transformer_feat_cls = transformer_feat[:, :, 0, :]
            transformer_feat_cls = transformer_feat_cls[:-1, :, :]
            normed_feat = self.l2_normalize(transformer_feat_cls)

            last_layer_feat = all_hidden[-2].float()
            if attention_mask is not None:
                mask = attention_mask.unsqueeze(-1).expand(last_layer_feat.size()).float()
                mask_sum = torch.clamp(mask.sum(dim=1), min=1e-4)
                pooled_output = torch.sum(last_layer_feat * mask, dim=1) / mask_sum
            else:
                pooled_output = torch.mean(last_layer_feat, dim=1)
            pooled_output = self.dropout(pooled_output)
            teacher_logits = self.classifier(pooled_output)
        return normed_feat, teacher_logits

    def __getattr__(self, name):
        try:
            return super().__getattr__(name)
        except AttributeError:
            return getattr(self.base_model, name)


def load_teacher_model():
    base_model = AutoModelForCausalLM.from_pretrained(
        TEACHER_BASE_MODEL_PATH,
        device_map="auto",
        trust_remote_code=True,
        torch_dtype=torch.float16,
        low_cpu_mem_usage=True,
        attn_implementation="flash_attention_2"
    )
    base_model.gradient_checkpointing_enable()
    base_model.config.use_cache = False

    model_with_head = StarCoderForPKD(
        base_model=base_model,
        num_labels=NUM_LABELS
    )

    lora_config = LoraConfig.from_pretrained(TEACHER_CHECKPOINT_DIR)
    teacher_model = PeftModel.from_pretrained(
        model_with_head,
        TEACHER_CHECKPOINT_DIR,
        config=lora_config
    )

    peft_state_dict = teacher_model.state_dict()
    target_prefixes = ["base_model.model.classifier.", "classifier.", "base_model.classifier."]
    classifier_loaded = False
    required_keys = set(teacher_model.classifier.state_dict().keys())

    for prefix in target_prefixes:
        classifier_params = {
            k.replace(prefix, ""): v for k, v in peft_state_dict.items() if k.startswith(prefix)
        }
        if classifier_params and set(classifier_params.keys()) == required_keys:
            teacher_model.classifier.load_state_dict(classifier_params)
            classifier_loaded = True
            break

    if not classifier_loaded:
        raise ValueError("教师模型分类头权重加载失败！请检查Checkpoint路径")

    for param in teacher_model.parameters():
        param.requires_grad = False
    teacher_model.eval()
    return teacher_model


