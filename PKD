def load_and_preprocess_data(force_reload=False):
    os.makedirs(DATA_CACHE_DIR, exist_ok=True)
    cache_files = {
        "tokenized_train": os.path.join(DATA_CACHE_DIR, "tokenized_train.pkl"),
        "tokenized_val": os.path.join(DATA_CACHE_DIR, "tokenized_val.pkl"),
        "tokenized_test": os.path.join(DATA_CACHE_DIR, "tokenized_test.pkl")
    }

    if not force_reload and all(os.path.exists(f) for f in cache_files.values()):
        with open(cache_files["tokenized_train"], "rb") as f:
            tokenized_train = pickle.load(f)
        with open(cache_files["tokenized_val"], "rb") as f:
            tokenized_val = pickle.load(f)
        with open(cache_files["tokenized_test"], "rb") as f:
            tokenized_test = pickle.load(f)
        data_collator = DualTokenizerDataCollator(teacher_tokenizer, student_tokenizer)
        return tokenized_train, tokenized_val, tokenized_test, data_collator

    dataset = load_dataset(DATASET_NAME)

    def preprocess_function(examples):
        code_field = "func_clean"
        if code_field not in examples:
            raise ValueError(f"数据集缺失 {code_field} 字段！")
        texts = examples[code_field]

        teacher_tokenized = teacher_tokenizer(
            texts, truncation=True, max_length=MAX_SEQ_LENGTH, padding=False, return_attention_mask=True
        )
        student_tokenized = student_tokenizer(
            texts, truncation=True, max_length=MAX_SEQ_LENGTH, padding=False, return_attention_mask=True
        )
        labels = examples["target"]
        if isinstance(labels[0], bool):
            labels = [1 if label else 0 for label in labels]

        return {
            "teacher_input_ids": teacher_tokenized["input_ids"],
            "teacher_attention_mask": teacher_tokenized["attention_mask"],
            "student_input_ids": student_tokenized["input_ids"],
            "student_attention_mask": student_tokenized["attention_mask"],
            "labels": labels
        }

    tokenized_train = dataset["train"].map(
        preprocess_function, batched=True, remove_columns=dataset["train"].column_names
    )
    tokenized_val = dataset["validation"].map(
        preprocess_function, batched=True, remove_columns=dataset["validation"].column_names
    )
    tokenized_test = dataset["test"].map(
        preprocess_function, batched=True, remove_columns=dataset["test"].column_names
    )

    with open(cache_files["tokenized_train"], "wb") as f:
        pickle.dump(tokenized_train, f)
    with open(cache_files["tokenized_val"], "wb") as f:
        pickle.dump(tokenized_val, f)
    with open(cache_files["tokenized_test"], "wb") as f:
        pickle.dump(tokenized_test, f)

    data_collator = DualTokenizerDataCollator(teacher_tokenizer, student_tokenizer)
    return tokenized_train, tokenized_val, tokenized_test, data_collator


class DualTokenizerDataCollator:
    def __init__(self, teacher_tokenizer, student_tokenizer):
        self.teacher_tokenizer = teacher_tokenizer
        self.student_tokenizer = student_tokenizer
        self.teacher_pad_id = teacher_tokenizer.pad_token_id
        self.student_pad_id = student_tokenizer.pad_token_id
        self.max_length = MAX_SEQ_LENGTH

    def __call__(self, features):
        teacher_input_ids = [f["teacher_input_ids"] for f in features]
        teacher_attention_masks = [f["teacher_attention_mask"] for f in features]
        padded_teacher_ids, padded_teacher_masks = self._pad_single_tokenizer(
            teacher_input_ids, teacher_attention_masks, self.teacher_pad_id
        )

        student_input_ids = [f["student_input_ids"] for f in features]
        student_attention_masks = [f["student_attention_mask"] for f in features]
        padded_student_ids, padded_student_masks = self._pad_single_tokenizer(
            student_input_ids, student_attention_masks, self.student_pad_id
        )

        labels = [f["labels"] for f in features]

        return {
            "teacher_input_ids": torch.tensor(padded_teacher_ids, dtype=torch.long),
            "teacher_attention_mask": torch.tensor(padded_teacher_masks, dtype=torch.long),
            "student_input_ids": torch.tensor(padded_student_ids, dtype=torch.long),
            "student_attention_mask": torch.tensor(padded_student_masks, dtype=torch.long),
            "labels": torch.tensor(labels, dtype=torch.long)
        }

    def _pad_single_tokenizer(self, input_ids_list, attention_masks_list, pad_id):
        padded_ids = []
        padded_masks = []
        for ids, mask in zip(input_ids_list, attention_masks_list):
            if len(ids) < self.max_length:
                padded_id = ids + [pad_id] * (self.max_length - len(ids))
                padded_mask = mask + [0] * (self.max_length - len(mask))
            else:
                padded_id = ids[:self.max_length]
                padded_mask = mask[:self.max_length]
            padded_ids.append(padded_id)
            padded_masks.append(padded_mask)
        return padded_ids, padded_masks


tokenized_train, tokenized_val, tokenized_test, data_collator = load_and_preprocess_data()


def compute_metrics(eval_pred: EvalPrediction):
    predictions = eval_pred.predictions
    labels = eval_pred.label_ids

    if isinstance(predictions, list):
        predictions = np.concatenate([p for p in predictions if p is not None], axis=0)
    elif isinstance(predictions, torch.Tensor):
        predictions = predictions.cpu().numpy()
    if isinstance(labels, list):
        labels = np.concatenate([l for l in labels if l is not None], axis=0)
    elif isinstance(labels, torch.Tensor):
        labels = labels.cpu().numpy()

    if len(predictions.shape) != 2:
        predictions = predictions.reshape(-1, NUM_LABELS)
    labels = labels.reshape(-1)

    preds = np.argmax(predictions, axis=1)
    accuracy = accuracy_score(labels, preds)
    precision_bin, recall_bin, f1_bin, _ = precision_recall_fscore_support(
        labels, preds, average="binary", zero_division=0
    )
    precision_per_cls, recall_per_cls, f1_per_cls, _ = precision_recall_fscore_support(
        labels, preds, average=None, zero_division=0
    )

    non_defective_f1 = f1_per_cls[0]
    defective_f1 = f1_per_cls[1]
    if non_defective_f1 == 0.0:
        defective_f1 = -1.0

    metrics = {
        "accuracy": accuracy,
        "precision": precision_bin,
        "recall": recall_bin,
        "f1": f1_bin,
        "defective_precision": precision_per_cls[1],
        "defective_recall": recall_per_cls[1],
        "defective_f1": defective_f1,
        "non_defective_precision": precision_per_cls[0],
        "non_defective_recall": recall_per_cls[0],
        "non_defective_f1": non_defective_f1,
    }
    return metrics


def train_pkd():
    training_args = TrainingArguments(
        output_dir=f"{OUTPUT_DIR_BASE}/pkd-training",
        learning_rate=LEARNING_RATE,
        per_device_train_batch_size=BATCH_SIZE,
        per_device_eval_batch_size=16,
        num_train_epochs=NUM_EPOCHS,
        logging_dir=f"{OUTPUT_DIR_BASE}/pkd-logs",
        logging_steps=50,
        eval_strategy="epoch",
        save_strategy="epoch",
        load_best_model_at_end=True,
        metric_for_best_model="defective_f1",
        greater_is_better=True,
        report_to="none",
        fp16=False,
        fp16_full_eval=False,
        remove_unused_columns=False,
        gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,
        warmup_steps=0,
        lr_scheduler_type="linear",
        seed=FIXED_SEED,
        max_grad_norm=1.0,
        save_total_limit=MAX_CHECKPOINTS,
        gradient_checkpointing=False,
        logging_first_step=True,
        log_level="info"
    )

    class PKDTrainer(Trainer):
        def compute_loss(self, model, inputs, return_outputs=False, num_items_in_batch=None):
            outputs = model(**inputs)
            loss = outputs["loss"]
            return (loss, outputs) if return_outputs else loss

        def prediction_step(
                self,
                model,
                inputs,
                prediction_loss_only: bool,
                ignore_keys=None,
        ):
            student_inputs = {k: v for k, v in inputs.items() if not k.startswith("teacher_")}
            with torch.no_grad():
                outputs = model(**student_inputs)

            loss = outputs["loss"].detach() if outputs["loss"] is not None else None
            logits = outputs["logits"].detach()
            labels = inputs.get("labels").detach() if inputs.get("labels") is not None else None

            if prediction_loss_only:
                return (loss, None, None)
            else:
                return (loss, logits, labels)

        def _prepare_optimizer_and_scheduler(self, num_training_steps: int):
            super()._prepare_optimizer_and_scheduler(num_training_steps)
            if hasattr(self, 'scaler') and self.scaler is not None:
                self.scaler = None

    trainer = PKDTrainer(
        model=student_model,
        args=training_args,
        train_dataset=tokenized_train,
        eval_dataset=tokenized_val,
        data_collator=data_collator,
        compute_metrics=compute_metrics,
    )

    trainer.train()

    all_eval_results = trainer.state.log_history
    valid_eval_results = []
    for log in all_eval_results:
        if "eval_non_defective_f1" in log and log["eval_non_defective_f1"] != 0.0:
            valid_eval_results.append(log)

    if not valid_eval_results:
        return
    else:
        best_result = max(valid_eval_results, key=lambda x: x.get("eval_defective_f1", -1))
        best_epoch = best_result.get("epoch", "unknown")

        best_model_dir = f"{OUTPUT_DIR_BASE}/best-pkd-student-model"
        trainer.save_model(best_model_dir)
        student_tokenizer.save_pretrained(best_model_dir)

    test_results = trainer.evaluate(eval_dataset=tokenized_test)

    with open(f"{OUTPUT_DIR_BASE}/pkd_test_results.txt", "w") as f:
        for key, value in test_results.items():
            f.write(f"{key}: {value:.4f}\n" if isinstance(value, float) else f"{key}: {value}\n")


if __name__ == "__main__":
    os.makedirs(OUTPUT_DIR_BASE, exist_ok=True)
    train_pkd()

    import_utils.check_torch_load_is_safe = original_check
    modeling_utils.check_torch_load_is_safe = original_load_check
