def main():
    teacher_tokenizer = AutoTokenizer.from_pretrained(config.teacher_base_model_path, trust_remote_code=True, padding_side="right")
    if teacher_tokenizer.pad_token is None:
        teacher_tokenizer.pad_token = teacher_tokenizer.eos_token
    finetuned_model, finetuned_tokenizer = load_finetuned_student_model()
    distilled_model, distilled_tokenizer = load_distilled_student_model()
    pkd_model, pkd_tokenizer = load_pkd_student_model()

    teacher_model = load_teacher_model()

    teacher_dataloader, student_dataloader, true_labels = get_test_dataloader(teacher_tokenizer, finetuned_tokenizer)

    _, teacher_probs, teacher_pred_labels = model_infer(teacher_model, teacher_dataloader, is_teacher=True)
    _, finetuned_probs, finetuned_pred_labels = model_infer(
        finetuned_model, student_dataloader, is_teacher=False, is_finetuned=True
    )
    _, distilled_probs, distilled_pred_labels = model_infer(
        distilled_model, student_dataloader, is_teacher=False, is_finetuned=False
    )
    _, pkd_probs, pkd_pred_labels = model_infer(
        pkd_model, student_dataloader, is_teacher=False, is_finetuned=False
    )

    finetuned_agreement = calculate_agreement(teacher_pred_labels, finetuned_pred_labels, "FT（微调）(CodeBERT-base)")
    finetuned_gt_nll = calculate_gt_nll_error(teacher_probs, finetuned_probs, true_labels, "FT（微调）(CodeBERT-base)")
    distilled_agreement = calculate_agreement(teacher_pred_labels, distilled_pred_labels, "KD（蒸馏）")
    distilled_gt_nll = calculate_gt_nll_error(teacher_probs, distilled_probs, true_labels, "KD（蒸馏）")
    pkd_agreement = calculate_agreement(teacher_pred_labels, pkd_pred_labels, "PKD（逐层蒸馏）")
    pkd_gt_nll = calculate_gt_nll_error(teacher_probs, pkd_probs, true_labels, "PKD（逐层蒸馏）")

    metrics_finetuned = {
        "total_test_samples": int(len(true_labels)),
        "agreement(%)": finetuned_agreement
    }
    metrics_distilled = {
        "total_test_samples": int(len(true_labels)),
        "agreement(%)": distilled_agreement
    }
    metrics_pkd = {
        "total_test_samples": int(len(true_labels)),
        "agreement(%)": pkd_agreement
    }

    plot_error_distribution_comparison(
        distilled_gt_nll, finetuned_gt_nll, pkd_gt_nll
    )                          

    save_comparison_results(
        metrics_distilled, metrics_finetuned, metrics_pkd,
        distilled_gt_nll, finetuned_gt_nll, pkd_gt_nll
    )

