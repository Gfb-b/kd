import torch
import numpy as np
import random
import os
import pickle
from datasets import load_dataset
from transformers import (
    AutoModelForCausalLM,
    AutoTokenizer,
    TrainingArguments,
    DataCollatorWithPadding,
    Trainer,
    set_seed
)
from peft import LoraConfig, get_peft_model
from sklearn.metrics import accuracy_score, precision_recall_fscore_support

FIXED_SEED = 42

def set_all_seeds(seed=FIXED_SEED):
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False
    set_seed(seed)
    os.environ["PYTHONHASHSEED"] = str(seed)

set_all_seeds()

MODEL_PATH = "autodl-tmp/codellma"
DATASET_NAME = "claudios/ReVeal"
MAX_SEQ_LENGTH = 512
NUM_LABELS = 2
LORA_R = 16
LORA_ALPHA = 32
BATCH_SIZE = 16
NUM_EPOCHS_FULL = 4
GRADIENT_ACCUMULATION_STEPS = 2
OUTPUT_DIR_BASE = "autodl-tmp/codellama7b-reveal-no-quant"
DATA_CACHE_DIR = os.path.join(OUTPUT_DIR_BASE, "dataset_cache")
MAX_CHECKPOINTS = 2
CLASS_WEIGHTS = None

LEARNING_RATES = [1e-4, 2e-4, 3e-4]

tokenizer = AutoTokenizer.from_pretrained(
    MODEL_PATH,
    trust_remote_code=True,
    padding_side="right",
    add_prefix_space=False
)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
if tokenizer.unk_token is None:
    tokenizer.unk_token = tokenizer.eos_token

class CodeLlamaForVulnerabilityDetection(torch.nn.Module):
    def __init__(self, base_model, num_labels=NUM_LABELS, class_weights=None):
        super().__init__()
        self.base_model = base_model
        self.config = base_model.config
        self.config.num_labels = num_labels
        self.device = base_model.device
        self.class_weights = class_weights

        self.hidden_size = self.config.hidden_size

        self.classifier = torch.nn.Linear(self.hidden_size, num_labels).to(self.device)
        self.classifier.requires_grad_(True)
        self.dropout = torch.nn.Dropout(0.1).to(self.device)

        torch.nn.init.normal_(self.classifier.weight, std=0.02)
        if self.classifier.bias is not None:
            torch.nn.init.zeros_(self.classifier.bias)

    def forward(self, input_ids, attention_mask=None, labels=None, **kwargs):
        outputs = self.base_model(
            input_ids=input_ids,
            attention_mask=attention_mask,
            output_hidden_states=True,
            return_dict=True,
            use_cache=False
        )

        last_hidden_state = outputs.hidden_states[-1]

        if attention_mask is not None:
            mask = attention_mask.unsqueeze(-1).expand(last_hidden_state.size()).float()
            pooled_output = torch.sum(last_hidden_state * mask, dim=1) / torch.clamp(mask.sum(dim=1), min=1e-9)
        else:
            pooled_output = torch.mean(last_hidden_state, dim=1)

        pooled_output = self.dropout(pooled_output)
        logits = self.classifier(pooled_output)

        loss = None
        if labels is not None:
            labels = labels.to(logits.device)
            weight = self.class_weights.to(logits.device) if self.class_weights is not None else None
            loss_fct = torch.nn.CrossEntropyLoss(weight=weight)
            loss = loss_fct(logits.view(-1, self.config.num_labels), labels.view(-1))

        return {"loss": loss, "logits": logits}

    def prepare_inputs_for_generation(self, input_ids, **kwargs):
        return {"input_ids": input_ids}

    def __getattr__(self, name):
        try:
            return super().__getattr__(name)
        except AttributeError:
            return getattr(self.base_model, name)

    def save_pretrained(self, save_directory):
        os.makedirs(save_directory, exist_ok=True)
        self.base_model.save_pretrained(save_directory)
        torch.save(self.classifier.state_dict(), f"{save_directory}/classifier.pt")
        self.config.save_pretrained(save_directory)
        if self.class_weights is not None:
            torch.save(self.class_weights, f"{save_directory}/class_weights.pt")

def load_and_preprocess_data(force_reload=False):
    global CLASS_WEIGHTS
    os.makedirs(DATA_CACHE_DIR, exist_ok=True)
    cache_files = {
        "tokenized_train": os.path.join(DATA_CACHE_DIR, "tokenized_train.pkl"),
        "tokenized_val": os.path.join(DATA_CACHE_DIR, "tokenized_val.pkl"),
        "tokenized_test": os.path.join(DATA_CACHE_DIR, "tokenized_test.pkl")
    }

    if not force_reload and all(os.path.exists(f) for f in cache_files.values()):
        with open(cache_files["tokenized_train"], "rb") as f:
            tokenized_train = pickle.load(f)
        with open(cache_files["tokenized_val"], "rb") as f:
            tokenized_val = pickle.load(f)
        with open(cache_files["tokenized_test"], "rb") as f:
            tokenized_test = pickle.load(f)

        train_labels = tokenized_train["labels"]
        compute_class_weights(train_labels)

        data_collator = DataCollatorWithPadding(
            tokenizer=tokenizer,
            padding="max_length",
            max_length=MAX_SEQ_LENGTH,
            return_tensors="pt"
        )
        return tokenized_train, tokenized_val, tokenized_test, data_collator

    dataset = load_dataset(DATASET_NAME)

    def preprocess_function(examples):
        code_field = "functionSource"
        if code_field not in examples:
            raise ValueError(f"数据集缺失 {code_field} 字段，请检查数据集结构！")

        texts = examples[code_field]

        tokenized = tokenizer(
            texts,
            truncation=True,
            max_length=MAX_SEQ_LENGTH,
            padding=False,
            return_tensors=None,
            add_special_tokens=True
        )

        labels = examples["label"]
        if isinstance(labels[0], bool):
            labels = [1 if label else 0 for label in labels]
        tokenized["labels"] = labels

        return tokenized

    original_train = dataset["train"]

    tokenized_train = original_train.map(
        preprocess_function,
        batched=True,
        remove_columns=dataset["train"].column_names,
        desc="预处理训练集"
    )
    tokenized_val = dataset["validation"].map(
        preprocess_function,
        batched=True,
        remove_columns=dataset["validation"].column_names
    )
    tokenized_test = dataset["test"].map(
        preprocess_function,
        batched=True,
        remove_columns=dataset["test"].column_names
    )

    train_labels = tokenized_train["labels"]
    compute_class_weights(train_labels)

    with open(cache_files["tokenized_train"], "wb") as f:
        pickle.dump(tokenized_train, f)
    with open(cache_files["tokenized_val"], "wb") as f:
        pickle.dump(tokenized_val, f)
    with open(cache_files["tokenized_test"], "wb") as f:
        pickle.dump(tokenized_test, f)

    data_collator = DataCollatorWithPadding(
        tokenizer=tokenizer,
        padding="max_length",
        max_length=MAX_SEQ_LENGTH,
        return_tensors="pt"
    )

    return tokenized_train, tokenized_val, tokenized_test, data_collator

def compute_class_weights(labels):
    global CLASS_WEIGHTS
    total_samples = len(labels)
    num_classes = NUM_LABELS

    class_counts = np.bincount(labels, minlength=num_classes)
    weights = total_samples / (num_classes * class_counts + 1e-9)
    CLASS_WEIGHTS = torch.tensor(weights, dtype=torch.float32)

tokenized_train, tokenized_val, tokenized_test, data_collator = load_and_preprocess_data()

def compute_metrics(eval_pred):
    predictions, labels = eval_pred
    predictions = np.argmax(predictions, axis=1)

    accuracy = accuracy_score(labels, predictions)
    precision_bin, recall_bin, f1_bin, _ = precision_recall_fscore_support(
        labels, predictions, average="binary", zero_division=0
    )

    precision_per_cls, recall_per_cls, f1_per_cls, _ = precision_recall_fscore_support(
        labels, predictions, average=None, zero_division=0
    )

    return {
        "accuracy": accuracy,
        "precision": precision_bin,
        "recall": recall_bin,
        "f1": f1_bin,
        "defective_precision": precision_per_cls[1],
        "defective_recall": recall_per_cls[1],
        "defective_f1": f1_per_cls[1],
        "non_defective_precision": precision_per_cls[0],
        "non_defective_recall": recall_per_cls[0],
        "non_defective_f1": f1_per_cls[0]
    }

def train_with_lr(learning_rate):
    output_dir = f"{OUTPUT_DIR_BASE}/lr_{learning_rate}"
    os.makedirs(output_dir, exist_ok=True)

    base_model = AutoModelForCausalLM.from_pretrained(
        MODEL_PATH,
        device_map="auto",
        trust_remote_code=True,
        torch_dtype=torch.float16,
        low_cpu_mem_usage=True
    )

    base_model.gradient_checkpointing_enable()
    base_model.config.use_cache = False

    model_with_head = CodeLlamaForVulnerabilityDetection(
        base_model,
        class_weights=CLASS_WEIGHTS
    )

    target_modules = [
        "q_proj", "k_proj", "v_proj", "o_proj"
    ]

    lora_config = LoraConfig(
        r=LORA_R,
        lora_alpha=LORA_ALPHA,
        target_modules=target_modules,
        lora_dropout=0.1,
        bias="none",
        task_type="CAUSAL_LM"
    )
    model_with_lora = get_peft_model(model_with_head, lora_config)
    model_with_lora.print_trainable_parameters()

    training_args = TrainingArguments(
        output_dir=f"{output_dir}/final-training",
        learning_rate=learning_rate,
        per_device_train_batch_size=BATCH_SIZE,
        per_device_eval_batch_size=16,
        num_train_epochs=NUM_EPOCHS_FULL,
        logging_dir=f"{output_dir}/final-logs",
        logging_steps=50,
        eval_strategy="steps",
        eval_steps=50,
        save_strategy="steps",
        save_steps=50,
        load_best_model_at_end=True,
        metric_for_best_model="defective_f1",
        greater_is_better=True,
        report_to="none",
        fp16=True,
        remove_unused_columns=False,
        gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,
        gradient_checkpointing=False,
        dataloader_pin_memory=True,
        warmup_steps=227,
        lr_scheduler_type="linear",
        seed=FIXED_SEED,
        max_grad_norm=1.0,
        save_total_limit=MAX_CHECKPOINTS,
    )

    class CustomTrainer(Trainer):
        def training_step(self, model, inputs, num_items_in_batch):
            model.train()
            inputs = self._prepare_inputs(inputs)

            with self.compute_loss_context_manager():
                outputs = model(**inputs)
                loss = outputs["loss"]

            loss = loss.mean()

            if self.args.gradient_accumulation_steps > 1:
                loss = loss / self.args.gradient_accumulation_steps

            self.accelerator.backward(loss)

            return loss.detach()

    trainer = CustomTrainer(
        model=model_with_lora,
        args=training_args,
        train_dataset=tokenized_train,
        eval_dataset=tokenized_val,
        data_collator=data_collator,
        compute_metrics=compute_metrics,
        processing_class=tokenizer
    )

    trainer.train()

    best_model_dir = f"{output_dir}/best-model"
    trainer.save_model(best_model_dir)
    tokenizer.save_pretrained(best_model_dir)

    test_results = trainer.evaluate(eval_dataset=tokenized_test)

    with open(f"{output_dir}/test_results.txt", "w") as f:
        for key, value in test_results.items():
            f.write(f"{key}: {value:.4f}\n" if isinstance(value, float) else f"{key}: {value}\n")

if __name__ == "__main__":
    os.makedirs(OUTPUT_DIR_BASE, exist_ok=True)
    for lr in LEARNING_RATES:
        train_with_lr(lr)
