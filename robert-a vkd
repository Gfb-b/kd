class Qwen2CoderForVulnerabilityDetection(torch.nn.Module):
    def __init__(self, base_model, num_labels=2, class_weights=None):
        super().__init__()
        self.base_model = base_model.to(device)
        self.config = base_model.config
        self.config.num_labels = num_labels
        self.class_weights = class_weights.half() if class_weights is not None else None
        self.hidden_size = self.config.hidden_size
        self.classifier = torch.nn.Linear(self.hidden_size, num_labels).to(device, dtype=torch.float16)
        self.dropout = torch.nn.Dropout(0.1).to(device)
        torch.nn.init.normal_(self.classifier.weight, std=0.02)
        if self.classifier.bias is not None:
            torch.nn.init.zeros_(self.classifier.bias)

    def forward(self, input_ids, attention_mask=None, **kwargs):
        input_ids = input_ids.to(device)
        if attention_mask is not None:
            attention_mask = attention_mask.to(device)

        outputs = self.base_model(input_ids=input_ids, attention_mask=attention_mask, output_hidden_states=True, return_dict=True, use_cache=False)
        lhs = outputs.hidden_states[-1]

        if attention_mask is not None:
            m = attention_mask.unsqueeze(-1).expand(lhs.size()).half()
            po = torch.sum(lhs * m, dim=1) / torch.clamp(m.sum(dim=1), min=1e-9)
        else:
            po = torch.mean(lhs, dim=1)

        po = self.dropout(po)
        logits = self.classifier(po)
        return {"logits": logits}

    def __getattr__(self, name):
        try:
            return super().__getattr__(name)
        except AttributeError:
            return getattr(self.base_model, name)

def load_teacher_model(config):
    logger.info(f"{config.teacher_checkpoint_dir}")
    base_model = AutoModelForCausalLM.from_pretrained(
        config.teacher_base_model_path,
        device_map="auto",
        trust_remote_code=True,
        torch_dtype=torch.float16,
        low_cpu_mem_usage=True,
        attn_implementation="flash_attention_2"
    )
    base_model.gradient_checkpointing_enable()
    base_model.config.use_cache = False

    m = Qwen2CoderForVulnerabilityDetection(base_model=base_model, num_labels=config.num_labels)
    lc = LoraConfig.from_pretrained(config.teacher_checkpoint_dir)
    tm = PeftModel.from_pretrained(m, config.teacher_checkpoint_dir, config=lc)
    
    sd = tm.state_dict()
    p = ["base_model.model.classifier.", "classifier.", "base_model.classifier."]
    cl = False
    rk = set(tm.classifier.state_dict().keys())

    for x in p:
        cp = {k.replace(x, ""): v for k, v in sd.items() if k.startswith(x)}
        if cp and set(cp.keys()) == rk:
            tm.classifier.load_state_dict(cp)
            logger.info(f"{x}")
            cl = True
            break

    if not cl:
        raise ValueError()

    for param in tm.parameters():
        param.requires_grad = False
    tm.eval()
    return tm.to(device)

