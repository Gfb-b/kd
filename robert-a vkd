class LogitsDistillationTrainer(Trainer):
    def __init__(self, *args, **kwargs):
        self.temperature = kwargs.pop("temperature", 3.0)
        self.alpha = kwargs.pop("alpha", 0.7)
        self.esp = kwargs.pop("early_stopping_patience", 0)
        self.et = kwargs.pop("early_stopping_threshold", 1e-5)
        self.bm = None
        self.esc = 0
        self.lem = None
        super().__init__(*args, **kwargs)

    def compute_loss(self, model, inputs, return_outputs=False, num_items_in_batch=None):
        htl = "teacher_logits" in inputs
        tlg = None
        if htl:
            tlg = inputs.pop("teacher_logits").to(device)

        l = inputs.get("labels").to(device)
        o = model(** inputs)
        slg = o["logits"]
        hl = F.cross_entropy(slg, l)

        if htl and tlg is not None:
            slp = F.log_softmax(slg / self.temperature, dim=1)
            tp = F.softmax(tlg / self.temperature, dim=1)
            kl = F.kl_div(slp, tp, reduction="batchmean") * (self.temperature **2)
            total = (1 - self.alpha) * hl + self.alpha * kl
            self.log({"train/hard_loss": hl.item()})
            self.log({"train/kl_loss": kl.item()})
        else:
            total = hl
            self.log({"eval/loss": hl.item()})
        return (total, o) if return_outputs else total

    def evaluation_loop(self, *args, **kwargs):
        out = super().evaluation_loop(*args, **kwargs)
        m = out.metrics
        if m:
            self.lem = m.copy()
            mn = self.args.metric_for_best_model
            if mn in m:
                cm = m[mn]
                if self.bm is None:
                    self.bm = cm
                    logger.info(f"{mn} {cm:.6f}")
                else:
                    imp = cm - self.bm
                    if imp > self.et:
                        self.bm = cm
                        logger.info(f"{mn} {cm:.6f} {imp:.6f}")
                    else:
                        logger.info(f"{mn} {cm:.6f} {self.bm:.6f}")
        return out

    def _save_checkpoint(self, model, trial):
        cs = self.state.global_step
        super()._save_checkpoint(model, trial)
        logger.info(f"{cs}")
        cm = self.lem
        if cm and isinstance(cm, dict) and len(cm) > 0:
            rm = "eval_f1"
            if rm in cm:
                cf1 = cm[rm]
                logger.info(f"{cs} {cf1:.4f}")
                manage_checkpoints(config, cs, cf1)
            else:
                logger.warning(f"{rm} {list(cm.keys())}")
        else:
            logger.debug(f"{cs}")

config = None

def main():
    global config
    config = Config()
    os.makedirs(config.output_dir, exist_ok=True)
    os.makedirs(config.best_model_dir, exist_ok=True)
    os.makedirs(config.teacher_data_cache_dir, exist_ok=True)
    os.makedirs(config.student_data_cache_dir, exist_ok=True)
    os.makedirs(config.logits_storage_dir, exist_ok=True)

    logger.info("1")
    logger.info(f"{config.teacher_base_model_path}")
    tt = AutoTokenizer.from_pretrained(config.teacher_base_model_path, trust_remote_code=True, padding_side="right")
    tt.pad_token = tt.eos_token
    st = get_custom_tokenizer()
    rd = load_devign_data(config.dataset_name, config.student_data_cache_dir)

    ttr, tv, tte = preprocess_dataset_for_model(dataset=rd, tokenizer=tt, cache_dir=config.teacher_data_cache_dir, model_type="teacher")
    str_, sv, ste = preprocess_dataset_for_model(dataset=rd, tokenizer=st, cache_dir=config.student_data_cache_dir, model_type="student")

    str_ = CodeBERT_DevignDataset(str_)
    sv = CodeBERT_DevignDataset(sv)
    ste = CodeBERT_DevignDataset(ste)

    tm = load_teacher_model(config)
    tl, li = generate_and_save_teacher_logits(teacher_model=tm, dataset=ttr, tokenizer=tt, config=config)
    ld = LogitsDataset(student_dataset=str_, logits=tl, indices=li)
    dc = DataCollatorWithPadding(tokenizer=st)

    m = load_student_model(config)
    tts = (len(ld) // (config.batch_size * config.gradient_accumulation_steps)) * config.epochs
    logger.info(f"{tts}")

    ta = {
        "output_dir": config.output_dir, "num_train_epochs": config.epochs,
        "per_device_train_batch_size": config.batch_size, "per_device_eval_batch_size": config.eval_batch_size,
        "learning_rate": config.learning_rate, "warmup_steps": config.warmup_steps,
        "logging_steps": config.logging_steps, "eval_strategy": config.eval_strategy, 
        "save_strategy": config.save_strategy,  "load_best_model_at_end": True,
        "metric_for_best_model": "eval_defective_f1", "greater_is_better": True,
        "fp16": torch.cuda.is_available(), "max_grad_norm": config.max_grad_norm,
        "report_to": "none", "gradient_accumulation_steps": config.gradient_accumulation_steps,
        "remove_unused_columns": False
    }
    targs = TrainingArguments(**ta)
    opt = AdamW(get_optimizer_params(m, config), eps=config.adam_eps, betas=(config.adam_beta1, config.adam_beta2))
    sch = get_linear_schedule_with_warmup(opt, config.warmup_steps, tts)

    trainer = LogitsDistillationTrainer(
        model=m, args=targs, train_dataset=ld, eval_dataset=sv,
        compute_metrics=compute_evaluation_metrics, data_collator=dc,
        optimizers=(opt, sch), temperature=config.distill_temperature, alpha=config.alpha
    )

    logger.info("1")
    trainer.train()
    vr = trainer.evaluate(sv)
    bof = save_best_model(m, st, vr["eval_f1"], 0.0, config, vr)
    trainer.model = m
    ter = trainer.evaluate(ste)
    log_full_metrics(ter, "test")

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        logger.error(f"{str(e)}", exc_info=True)
        raise
    finally:
        import_utils.check_torch_load_is_safe = original_check
        modeling_utils.check_torch_load_is_safe = original_load_check
