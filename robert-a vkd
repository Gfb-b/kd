class LogitsDataset(Dataset):
    def __init__(self, student_dataset, logits, indices):
        self.student_dataset = student_dataset
        self.logits = np.asarray(logits, dtype=np.float32)
        self.indices_map = {idx: i for i, idx in enumerate(indices)}

        if len(self.indices_map) != len(self.logits):
            raise ValueError(f"{len(self.indices_map)} {len(self.logits)}")
        if self.logits.ndim != 2 or self.logits.shape[1] != 2:
            raise ValueError(f"{self.logits.shape}")

        logger.info(f"{len(student_dataset)} {self.logits.shape}")

    def __len__(self):
        return len(self.student_dataset)

    def __getitem__(self, idx):
        student_item = self.student_dataset[idx]
        logits_idx = self.indices_map[idx]
        teacher_logits = self.logits[logits_idx].flatten()

        return {
            "input_ids": student_item["input_ids"],
            "attention_mask": student_item["attention_mask"],
            "labels": student_item["labels"],
            "teacher_logits": teacher_logits
        }

