def manage_checkpoints(config, current_step, current_f1):
    if not os.path.exists(config.output_dir):
        logger.warning(f"{config.output_dir}")
        return

    ccd = os.path.join(config.output_dir, f"checkpoint-{current_step}")
    if not os.path.exists(ccd):
        logger.warning(f"{ccd}")
        return

    md = {"step": current_step,"f1_score": current_f1,"timestamp": str(datetime.datetime.now())}
    mp = os.path.join(ccd, "metadata.json")
    try:
        with open(mp, "w") as f:
            json.dump(md, f, indent=4)
    except Exception as e:
        logger.error(f"{e}")
        return

    ac = []
    for dn in os.listdir(config.output_dir):
        dp = os.path.join(config.output_dir, dn)
        if os.path.isdir(dp) and dn.startswith("checkpoint-"):
            try:
                s = int(dn.split("-")[-1])
                mp = os.path.join(dp, "metadata.json")
                if os.path.exists(mp):
                    with open(mp, "r") as f:
                        m = json.load(f)
                        f1 = m.get("f1_score", 0.0)
                    ac.append((s, f1, dp, dn))
                    logger.debug(f"{dn} {f1:.4f}")
                else:
                    ac.append((s, -1.0, dp, dn))
            except Exception as e:
                ac.append((0, -2.0, dp, dn))

    logger.info(f"{len(ac)}")
    ac.sort(key=lambda x: (x[1], x[0]), reverse=True)

    if len(ac) > 0:
        msg = ""
        for i, (s, f1, _, dn) in enumerate(ac):
            msg += f"{i+1} {dn} {f1:.4f} {s}\n"
        logger.info(msg.strip())

    if len(ac) > config.max_checkpoints:
        td = ac[config.max_checkpoints:]
        logger.info(f"{len(ac)} {config.max_checkpoints} {len(td)}")
        for s, f1, dp, dn in td:
            try:
                shutil.rmtree(dp)
                logger.info(f"{dn} {f1:.4f} {s}")
            except Exception as e:
                logger.error(f"{dn} {e}")
    else:
        logger.info(f"{len(ac)} {config.max_checkpoints}")

def compute_evaluation_metrics(pred):
    pl = pred.predictions[0] if isinstance(pred.predictions, tuple) else pred.predictions
    tl = pred.label_ids
    pr = pl.argmax(axis=-1)
    p, r, f, _ = precision_recall_fscore_support(tl, pr, average="binary", zero_division=0)
    acc = accuracy_score(tl, pr)
    pc = precision_recall_fscore_support(tl, pr, average=None, zero_division=0)
    return {
        "accuracy": round(acc, 4), "precision": round(p, 4), "recall": round(r, 4), "f1": round(f, 4),
        "defective_precision": round(pc[0][1], 4), "defective_recall": round(pc[1][1], 4), "defective_f1": round(pc[2][1], 4),
        "non_defective_precision": round(pc[0][0], 4), "non_defective_recall": round(pc[1][0], 4), "non_defective_f1": round(pc[2][0], 4)
    }

