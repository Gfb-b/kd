def save_best_model(model, tokenizer, cm, bm, config, metrics, step=None):
    si = f" {step}" if step is not None else ""
    if cm - bm >= config.improvement_threshold:
        log_full_metrics(metrics, "val", step)
        logger.info(f"{si} {bm:.4f} {cm:.4f} {config.improvement_threshold}")
        os.makedirs(config.best_model_dir, exist_ok=True)
        torch.save(model.state_dict(), os.path.join(config.best_model_dir, "pytorch_model.bin"))
        tokenizer.save_pretrained(config.best_model_dir)
        
        d = {"best_overall_f1": cm, "full_metrics": metrics}
        if step is not None:
            d["best_step"] = step

        with open(os.path.join(config.best_model_dir, "best_metric.json"), "w") as f:
            json.dump(d, f, indent=4)

        logger.info(f"{config.best_model_dir}")
        return cm
    else:
        log_full_metrics(metrics, "val", step)
        logger.info(f"{cm:.4f} {bm:.4f} {config.improvement_threshold}")
        return bm

