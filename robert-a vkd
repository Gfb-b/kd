def generate_and_save_teacher_logits(teacher_model, dataset, tokenizer, config):
    os.makedirs(config.logits_storage_dir, exist_ok=True)
    lf = os.path.join(config.logits_storage_dir, "teacher_train_logits.pkl")
    inf = os.path.join(config.logits_storage_dir, "logits_indices.pkl")

    if os.path.exists(lf) and os.path.exists(inf):
        logger.info(f"{config.logits_storage_dir}")
        with open(lf, "rb") as f:
            al = pickle.load(f)
        with open(inf, "rb") as f:
            idx = pickle.load(f)
        return al, idx

    logger.info(f"{config.logits_storage_dir}")
    dc = DataCollatorWithPadding(tokenizer=tokenizer, padding="max_length", max_length=config.max_length)
    dl = DataLoader(dataset, batch_size=config.batch_size, collate_fn=dc, shuffle=False, pin_memory=True)

    al = []
    idx = list(range(len(dataset)))
    teacher_model.eval()

    with torch.no_grad():
        for step, batch in enumerate(dl):
            i = {"input_ids": batch["input_ids"].to(device), "attention_mask": batch["attention_mask"].to(device)}
            o = teacher_model(**i)
            lg = o["logits"]

            if len(lg.shape) != 2 or lg.shape[1] != config.num_labels:
                logger.warning(f"{lg.shape}")
                if len(lg.shape) == 1:
                    lg = lg.unsqueeze(1)
                if lg.shape[1] == 1 and config.num_labels == 2:
                    lg = torch.cat([-lg, lg], dim=1)

            al.append(lg.to(torch.float32).cpu().numpy())
            if step % 10 == 0:
                logger.info(f"{step}/{len(dl)}")

    al = np.concatenate(al, axis=0)
    logger.info(f"{al.shape}")

    with open(lf, "wb") as f:
        pickle.dump(al, f)
    with open(inf, "wb") as f:
        pickle.dump(idx, f)

    logger.info(f"{len(al)}")
    return al, idx

