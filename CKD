class CKDUtils:
    @staticmethod
    def layer_mapping(student_layer_idx, student_num_layers, teacher_num_layers, ratio):
        mapped_layer = student_layer_idx * ratio
        mapped_layer = np.clip(mapped_layer, 0, teacher_num_layers - 1)
        mapped_layer = min(max(round(mapped_layer), 0), teacher_num_layers - 1)
        return int(mapped_layer)

    @staticmethod
    def pairwise_relation(x, y):
        x_norm = F.normalize(x, p=2, dim=-1, eps=1e-8)
        y_norm = F.normalize(y, p=2, dim=-1, eps=1e-8)
        relation = 1 - torch.sum(x_norm * y_norm, dim=-1)
        return torch.clamp(relation, 0.0, 2.0)

    @staticmethod
    def triple_relation(x, y, z):
        x_y = x - y
        z_y = z - y
        x_y_norm = F.normalize(x_y, p=2, dim=-1, eps=1e-8)
        z_y_norm = F.normalize(z_y, p=2, dim=-1, eps=1e-8)
        relation = torch.sum(x_y_norm * z_y_norm, dim=-1)
        return torch.clamp(relation, -1.0, 1.0)

    @staticmethod
    def get_optimized_window_indices(seq_len, base_window_size=CKD_BASE_WINDOW_SIZE):
        fixed_window = min(base_window_size, seq_len // 2)
        
        indices = []
        for i in range(seq_len):
            start = max(0, i - fixed_window // 2)
            end = min(seq_len, i + fixed_window // 2 + 1)
            j_indices = np.arange(start, end)
            j_indices = j_indices[j_indices != i]
            pairs = [(i, int(j)) for j in j_indices]
            indices.extend(pairs)
            
            for j in j_indices:
                k_indices = np.arange(j + 1, end)
                k_indices = k_indices[k_indices != i]
                triples = [(i, int(j), int(k)) for k in k_indices]
                indices.extend(triples)
        
        indices = list(set(indices))
        return indices

    @staticmethod
    def compute_kd_loss(student_logits, teacher_logits, temperature=KD_TEMPERATURE):
        student_soft = F.softmax(student_logits / temperature, dim=-1)
        teacher_soft = F.softmax(teacher_logits / temperature, dim=-1)
        
        kd_loss = F.cross_entropy(
            input=student_soft.log(),
            target=teacher_soft,
            reduction='mean'
        )

        
        return kd_loss

    @staticmethod
    def compute_multi_layer_ckd_loss(
        student_hidden_states,
        teacher_hidden_states,
        student_projection,
        layer_mapping_ratio,
        window_indices,
        attention_mask=None,
        device=None
    ):
        total_tr_loss = 0.0
        total_ltr_loss = 0.0
        layer_count = 0
        
        student_num_layers = len(student_hidden_states)
        teacher_num_layers = len(teacher_hidden_states)
        
        for student_layer_idx in range(8, student_num_layers - 1):
            teacher_layer_idx = CKDUtils.layer_mapping(
                student_layer_idx, student_num_layers, teacher_num_layers, layer_mapping_ratio
            )
            
            student_hidden = student_hidden_states[student_layer_idx].to(device)
            teacher_hidden = teacher_hidden_states[teacher_layer_idx].to(device)
            
            student_hidden_proj = student_projection(student_hidden)
            if student_hidden_proj.shape[1] != MAX_SEQ_LENGTH:
                if student_hidden_proj.shape[1] > MAX_SEQ_LENGTH:
                    student_hidden_proj = student_hidden_proj[:, :MAX_SEQ_LENGTH, :]
                else:
                    pad_len = MAX_SEQ_LENGTH - student_hidden_proj.shape[1]
                    student_hidden_proj = F.pad(student_hidden_proj, (0,0,0,pad_len), value=0)
            
            if teacher_hidden.shape[1] != MAX_SEQ_LENGTH:
                if teacher_hidden.shape[1] > MAX_SEQ_LENGTH:
                    teacher_hidden = teacher_hidden[:, :MAX_SEQ_LENGTH, :]
                else:
                    pad_len = MAX_SEQ_LENGTH - teacher_hidden.shape[1]
                    teacher_hidden = F.pad(teacher_hidden, (0,0,0,pad_len), value=0)
            
            valid_pair_indices = []
            valid_triple_indices = []
            if attention_mask is not None:
                attention_mask = attention_mask.to(device)
                for idx in window_indices:
                    if len(idx) == 2:
                        i, j = idx
                        if (attention_mask[:, i].any() and attention_mask[:, j].any()):
                            valid_pair_indices.append(idx)
                    elif len(idx) == 3:
                        i, j, k = idx
                        if (attention_mask[:, i].any() and attention_mask[:, j].any() and attention_mask[:, k].any()):
                            valid_triple_indices.append(idx)
            else:
                valid_pair_indices = [idx for idx in window_indices if len(idx)==2]
                valid_triple_indices = [idx for idx in window_indices if len(idx)==3]
            
            tr2_loss = 0.0
            tr3_loss = 0.0
            pair_count = 0
            triple_count = 0

            for i, j in valid_pair_indices:
                s_pair = CKDUtils.pairwise_relation(student_hidden_proj[:, i], student_hidden_proj[:, j])
                t_pair = CKDUtils.pairwise_relation(teacher_hidden[:, i], teacher_hidden[:, j])
                tr2_loss += F.mse_loss(s_pair, t_pair)
                pair_count += 1
            
            for i, j, k in valid_triple_indices:
                s_triple = CKDUtils.triple_relation(student_hidden_proj[:, i], student_hidden_proj[:, j], student_hidden_proj[:, k])
                t_triple = CKDUtils.triple_relation(teacher_hidden[:, i], teacher_hidden[:, j], teacher_hidden[:, k])
                tr3_loss += F.mse_loss(s_triple, t_triple)
                triple_count += 1
            
            tr2_loss = tr2_loss / max(pair_count, 1)
            tr3_loss = tr3_loss / max(triple_count, 1)
            tr_loss = tr2_loss + CKD_LAMBDA_TR * tr3_loss

            ltr_loss = 0.0
            ltr_count = 0
            if student_layer_idx < student_num_layers - 2:
                student_next_hidden = student_hidden_states[student_layer_idx + 1].to(device)
                teacher_next_idx = CKDUtils.layer_mapping(
                    student_layer_idx + 1, student_num_layers, teacher_num_layers, layer_mapping_ratio
                )
                teacher_next_hidden = teacher_hidden_states[teacher_next_idx].to(device)

                student_next_proj = student_projection(student_next_hidden)
                if student_next_proj.shape[1] != MAX_SEQ_LENGTH:
                    if student_next_proj.shape[1] > MAX_SEQ_LENGTH:
                        student_next_proj = student_next_proj[:, :MAX_SEQ_LENGTH, :]
                    else:
                        pad_len = MAX_SEQ_LENGTH - student_next_proj.shape[1]
                        student_next_proj = F.pad(student_next_proj, (0,0,0,pad_len), value=0)
                
                if teacher_next_hidden.shape[1] != MAX_SEQ_LENGTH:
                    if teacher_next_hidden.shape[1] > MAX_SEQ_LENGTH:
                        teacher_next_hidden = teacher_next_hidden[:, :MAX_SEQ_LENGTH, :]
                    else:
                        pad_len = MAX_SEQ_LENGTH - teacher_next_hidden.shape[1]
                        teacher_next_hidden = F.pad(teacher_next_hidden, (0,0,0,pad_len), value=0)
                
                for i, j in valid_pair_indices:
                    s_ltr = CKDUtils.pairwise_relation(student_hidden_proj[:, i], student_next_proj[:, j])
                    t_ltr = CKDUtils.pairwise_relation(teacher_hidden[:, i], teacher_next_hidden[:, j])
                    ltr_loss += F.mse_loss(s_ltr, t_ltr)
                    ltr_count += 1
            
            ltr_loss = ltr_loss / max(ltr_count, 1)
            
            total_tr_loss += tr_loss
            total_ltr_loss += ltr_loss
            layer_count += 1
        
        avg_tr_loss = total_tr_loss / max(layer_count, 1)
        avg_ltr_loss = total_ltr_loss / max(layer_count, 1)
        return avg_tr_loss, avg_ltr_loss

class CodeLlamaForVulnerabilityDetection(torch.nn.Module):
    def __init__(self, base_model, num_labels=2):
        super().__init__()
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.base_model = base_model.to(self.device)
        self.config = base_model.config
        self.config.num_labels = num_labels
        self.hidden_size = self.config.hidden_size

        self.classifier = torch.nn.Linear(self.hidden_size, num_labels).to(self.device, dtype=torch.float16)
        self.dropout = torch.nn.Dropout(0.1).to(self.device)
        torch.nn.init.normal_(self.classifier.weight, std=0.02)
        if self.classifier.bias is not None:
            torch.nn.init.zeros_(self.classifier.bias)

    def forward(self, input_ids, attention_mask=None, **kwargs):
        with torch.no_grad():
            if input_ids.shape[1] != MAX_SEQ_LENGTH:
                if input_ids.shape[1] > MAX_SEQ_LENGTH:
                    input_ids = input_ids[:, :MAX_SEQ_LENGTH]
                    attention_mask = attention_mask[:, :MAX_SEQ_LENGTH] if attention_mask is not None else None
                else:
                    pad_len = MAX_SEQ_LENGTH - input_ids.shape[1]
                    input_ids = F.pad(input_ids, (0, pad_len), value=self.base_model.config.pad_token_id)
                    if attention_mask is not None:
                        attention_mask = F.pad(attention_mask, (0, pad_len), value=0)
            
            if input_ids is None:
                batch_size = 0 if attention_mask is None else attention_mask.shape[0]
                return torch.zeros((batch_size, self.hidden_size), dtype=torch.float32).to(self.device), torch.zeros((batch_size, self.num_labels)).to(self.device)
            
            input_ids = input_ids.to(self.device)
            if attention_mask is not None:
                attention_mask = attention_mask.to(self.device)

            outputs = self.base_model(
                input_ids=input_ids,
                attention_mask=attention_mask,
                output_hidden_states=True,
                return_dict=True,
                use_cache=False
            )
            last_hidden_state = outputs.hidden_states[-2]

            if attention_mask is not None:
                mask = attention_mask.unsqueeze(-1).expand(last_hidden_state.size()).float()
                mask_sum = torch.clamp(mask.sum(dim=1), min=1e-6)
                pooled_output = torch.sum(last_hidden_state.float() * mask, dim=1) / mask_sum
            else:
                pooled_output = torch.mean(last_hidden_state.float(), dim=1)
        
        teacher_logits = self.classifier(self.dropout(pooled_output))
        return pooled_output.float(), teacher_logits.float()

    def get_full_outputs(self, input_ids, attention_mask=None):
        with torch.no_grad():
            if input_ids.shape[1] != MAX_SEQ_LENGTH:
                if input_ids.shape[1] > MAX_SEQ_LENGTH:
                    input_ids = input_ids[:, :MAX_SEQ_LENGTH]
                    attention_mask = attention_mask[:, :MAX_SEQ_LENGTH] if attention_mask is not None else None
                else:
                    pad_len = MAX_SEQ_LENGTH - input_ids.shape[1]
                    input_ids = F.pad(input_ids, (0, pad_len), value=self.base_model.config.pad_token_id)
                    if attention_mask is not None:
                        attention_mask = F.pad(attention_mask, (0, pad_len), value=0)
            
            input_ids = input_ids.to(self.device)
            attention_mask = attention_mask.to(self.device) if attention_mask is not None else None
            
            outputs = self.base_model(
                input_ids=input_ids,
                attention_mask=attention_mask,
                output_hidden_states=True,
                return_dict=True,
                use_cache=False
            )
        return outputs

    def __getattr__(self, name):
        try:
            return super().__getattr__(name)
        except AttributeError:
            return getattr(self.base_model, name)

def load_teacher_model():
    base_model = AutoModelForCausalLM.from_pretrained(
        TEACHER_BASE_MODEL_PATH,
        device_map="auto",
        trust_remote_code=True,
        torch_dtype=torch.float16,
        low_cpu_mem_usage=True,
        attn_implementation="flash_attention_2"
    )
    base_model.gradient_checkpointing_enable()
    base_model.config.use_cache = False

    model_with_head = CodeLlamaForVulnerabilityDetection(
        base_model=base_model,
        num_labels=NUM_LABELS
    )

    lora_config = LoraConfig.from_pretrained(TEACHER_CHECKPOINT_DIR)
    teacher_model = PeftModel.from_pretrained(
        model_with_head,
        TEACHER_CHECKPOINT_DIR,
        config=lora_config
    )

    peft_state_dict = teacher_model.state_dict()
    target_prefixes = ["base_model.model.classifier.", "classifier.", "base_model.classifier."]
    classifier_loaded = False
    required_keys = set(teacher_model.classifier.state_dict().keys())

    for prefix in target_prefixes:
        classifier_params = {
            k.replace(prefix, ""): v for k, v in peft_state_dict.items() if k.startswith(prefix)
        }
        if classifier_params and set(classifier_params.keys()) == required_keys:
            teacher_model.classifier.load_state_dict(classifier_params)
            classifier_loaded = True
            break

    if not classifier_loaded:
        raise ValueError("教师模型分类头权重加载失败！请检查Checkpoint路径")

    for param in teacher_model.parameters():
        param.requires_grad = False
    teacher_model.eval()
    return teacher_model

teacher_model = load_teacher_model()
