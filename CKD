class CodeBERTStudentModel(torch.nn.Module):
    def __init__(self, model_path, teacher_hidden_size, num_labels=NUM_LABELS):
        super().__init__()
        self.base_model = AutoModel.from_pretrained(
            model_path,
            device_map="auto",
            torch_dtype=torch.float32,
            low_cpu_mem_usage=True
        )
        self.base_model.gradient_checkpointing_enable()
        self.student_hidden_size = self.base_model.config.hidden_size
        self.teacher_hidden_size = teacher_hidden_size
        self.num_labels = num_labels
        self.device = next(self.base_model.parameters()).device

        self.dropout = torch.nn.Dropout(0.1).to(self.device)
        self.classifier = torch.nn.Linear(self.student_hidden_size, num_labels).to(self.device, dtype=torch.float32)
        torch.nn.init.normal_(self.classifier.weight, std=0.02)
        if self.classifier.bias is not None:
            torch.nn.init.zeros_(self.classifier.bias)

        if self.student_hidden_size != self.teacher_hidden_size:
            self.projection = torch.nn.Linear(
                self.student_hidden_size, self.teacher_hidden_size
            ).to(self.device, dtype=torch.float32)
            torch.nn.init.normal_(self.projection.weight, std=0.02)
            if self.projection.bias is not None:
                torch.nn.init.zeros_(self.projection.bias)
        else:
            self.projection = None

    def gradient_checkpointing_enable(self, gradient_checkpointing_kwargs=None):
        if hasattr(self.base_model, 'gradient_checkpointing_enable'):
            self.base_model.gradient_checkpointing_enable(gradient_checkpointing_kwargs=gradient_checkpointing_kwargs)

    def gradient_checkpointing_disable(self):
        if hasattr(self.base_model, 'gradient_checkpointing_disable'):
            self.base_model.gradient_checkpointing_disable()

    def forward(self, student_input_ids, student_attention_mask=None, labels=None, 
                teacher_input_ids=None, teacher_attention_mask=None):
        student_input_ids = student_input_ids.to(self.device)
        if student_attention_mask is not None:
            student_attention_mask = student_attention_mask.to(self.device)
        if teacher_input_ids is not None:
            teacher_input_ids = teacher_input_ids.to(self.device)
        if teacher_attention_mask is not None:
            teacher_attention_mask = teacher_attention_mask.to(self.device)

        if student_input_ids.shape[1] != MAX_SEQ_LENGTH:
            if student_input_ids.shape[1] > MAX_SEQ_LENGTH:
                student_input_ids = student_input_ids[:, :MAX_SEQ_LENGTH]
                student_attention_mask = student_attention_mask[:, :MAX_SEQ_LENGTH] if student_attention_mask is not None else None
            else:
                pad_len = MAX_SEQ_LENGTH - student_input_ids.shape[1]
                student_input_ids = F.pad(student_input_ids, (0, pad_len), value=self.base_model.config.pad_token_id)
                if student_attention_mask is not None:
                    student_attention_mask = F.pad(student_attention_mask, (0, pad_len), value=0)
        
        student_outputs = self.base_model(
            input_ids=student_input_ids,
            attention_mask=student_attention_mask,
            output_hidden_states=True,
            return_dict=True
        )
        student_hidden_states = list(student_outputs.hidden_states)
        student_last_hidden = student_hidden_states[-2]
        
        if student_attention_mask is not None:
            student_mask = student_attention_mask.unsqueeze(-1).expand(student_last_hidden.size()).float()
            student_feature = torch.sum(student_last_hidden * student_mask, dim=1) / torch.clamp(student_mask.sum(dim=1), min=1e-9)
        else:
            student_feature = torch.mean(student_last_hidden, dim=1)

        pooled_output = self.dropout(student_feature)
        student_logits = self.classifier(pooled_output)
        loss = None

        if labels is not None:
            labels = labels.to(self.device)
            cls_loss = torch.nn.CrossEntropyLoss()(student_logits.view(-1, self.num_labels), labels.view(-1))
            
            if teacher_input_ids is not None and teacher_attention_mask is not None:
                _, teacher_logits = teacher_model(
                    input_ids=teacher_input_ids,
                    attention_mask=teacher_attention_mask
                )
                teacher_logits = teacher_logits.to(self.device)
                
                teacher_full_outputs = self._get_teacher_full_outputs(teacher_input_ids, teacher_attention_mask)
                teacher_hidden_states = list(teacher_full_outputs.hidden_states)
                
                for i in range(len(teacher_hidden_states)):
                    th = teacher_hidden_states[i].to(self.device)
                    if th.shape[1] != MAX_SEQ_LENGTH:
                        if th.shape[1] > MAX_SEQ_LENGTH:
                            th = th[:, :MAX_SEQ_LENGTH, :]
                        else:
                            pad_len = MAX_SEQ_LENGTH - th.shape[1]
                            th = F.pad(th, (0,0,0,pad_len), value=0)
                    teacher_hidden_states[i] = th
                
                window_indices = CKDUtils.get_optimized_window_indices(MAX_SEQ_LENGTH)
                
                tr_loss, ltr_loss = CKDUtils.compute_multi_layer_ckd_loss(
                    student_hidden_states=student_hidden_states,
                    teacher_hidden_states=teacher_hidden_states,
                    student_projection=self.projection,
                    layer_mapping_ratio=LAYER_MAPPING_RATIO,
                    window_indices=window_indices,
                    attention_mask=teacher_attention_mask,
                    device=self.device
                )

                kd_loss = CKDUtils.compute_kd_loss(
                    student_logits=student_logits,
                    teacher_logits=teacher_logits,
                    temperature=KD_TEMPERATURE
                )

                ckd_loss = kd_loss + CKD_LAMBDA * (tr_loss + ltr_loss)
                loss = cls_loss + ckd_loss
            else:
                loss = cls_loss

        return {"loss": loss, "logits": student_logits}

    def _get_teacher_full_outputs(self, input_ids, attention_mask):
        with torch.no_grad():
            input_ids = input_ids.to(teacher_model.device)
            attention_mask = attention_mask.to(teacher_model.device) if attention_mask is not None else None
            outputs = teacher_model.get_full_outputs(input_ids, attention_mask)
        
        return outputs

def load_and_preprocess_data():
    if os.path.exists(DATA_CACHE_DIR):
        import shutil
        shutil.rmtree(DATA_CACHE_DIR)
    os.makedirs(DATA_CACHE_DIR, exist_ok=True)
    
    dataset = load_dataset(DATASET_NAME)

    def preprocess_function(examples):
        code_field = "functionSource"
        if code_field not in examples:
            raise ValueError(f"Reveal数据集缺失 {code_field} 字段！")
        texts = examples[code_field]
        
        teacher_tokenized = teacher_tokenizer(
            texts,
            truncation=True,
            max_length=MAX_SEQ_LENGTH,
            padding="max_length",
            return_attention_mask=True
        )
        student_tokenized = student_tokenizer(
            texts,
            truncation=True,
            max_length=MAX_SEQ_LENGTH,
            padding="max_length",
            return_attention_mask=True
        )
        
        labels = examples["label"]
        if isinstance(labels[0], bool):
            labels = [1 if label else 0 for label in labels]
        
        return {
            "teacher_input_ids": teacher_tokenized["input_ids"],
            "teacher_attention_mask": teacher_tokenized["attention_mask"],
            "student_input_ids": student_tokenized["input_ids"],
            "student_attention_mask": student_tokenized["attention_mask"],
            "labels": labels
        }

    tokenized_train = dataset["train"].map(
        preprocess_function, 
        batched=True, 
        remove_columns=dataset["train"].column_names
    )
    tokenized_val = dataset["validation"].map(
        preprocess_function, 
        batched=True, 
        remove_columns=dataset["validation"].column_names
    )
    tokenized_test = dataset["test"].map(
        preprocess_function, 
        batched=True, 
        remove_columns=dataset["test"].column_names
    )

    with open(os.path.join(DATA_CACHE_DIR, "tokenized_train.pkl"), "wb") as f:
        pickle.dump(tokenized_train, f)
    with open(os.path.join(DATA_CACHE_DIR, "tokenized_val.pkl"), "wb") as f:
        pickle.dump(tokenized_val, f)
    with open(os.path.join(DATA_CACHE_DIR, "tokenized_test.pkl"), "wb") as f:
        pickle.dump(tokenized_test, f)
    
    return tokenized_train, tokenized_val, tokenized_test

class DualTokenizerDataCollator:
    def __init__(self, teacher_tokenizer, student_tokenizer):
        self.teacher_tokenizer = teacher_tokenizer
        self.student_tokenizer = student_tokenizer
        self.teacher_pad_id = teacher_tokenizer.pad_token_id
        self.student_pad_id = student_tokenizer.pad_token_id
        self.max_length = MAX_SEQ_LENGTH

    def __call__(self, features):
        teacher_input_ids_list = [torch.tensor(f["teacher_input_ids"], dtype=torch.long) for f in features]
        teacher_attention_masks_list = [torch.tensor(f["teacher_attention_mask"], dtype=torch.long) for f in features]
        student_input_ids_list = [torch.tensor(f["student_input_ids"], dtype=torch.long) for f in features]
        student_attention_masks_list = [torch.tensor(f["student_attention_mask"], dtype=torch.long) for f in features]
        labels_list = [torch.tensor(f["labels"], dtype=torch.long) for f in features]

        teacher_input_ids = torch.stack(teacher_input_ids_list)
        teacher_attention_masks = torch.stack(teacher_attention_masks_list)
        student_input_ids = torch.stack(student_input_ids_list)
        student_attention_masks = torch.stack(student_attention_masks_list)
        labels = torch.stack(labels_list)

        return {
            "teacher_input_ids": teacher_input_ids,
            "teacher_attention_mask": teacher_attention_masks,
            "student_input_ids": student_input_ids,
            "student_attention_mask": student_attention_masks,
            "labels": labels
        }

teacher_tokenizer = AutoTokenizer.from_pretrained(
    TEACHER_TOKENIZER_PATH,
    trust_remote_code=True,
    padding_side="right",
    add_prefix_space=False
)
if teacher_tokenizer.pad_token is None:
    teacher_tokenizer.pad_token = teacher_tokenizer.eos_token

student_tokenizer = AutoTokenizer.from_pretrained(
    STUDENT_TOKENIZER_PATH,
    padding_side="right",
    add_prefix_space=False
)

tokenized_train, tokenized_val, tokenized_test = load_and_preprocess_data()
data_collator = DualTokenizerDataCollator(teacher_tokenizer, student_tokenizer)

def compute_metrics(eval_pred: EvalPrediction):
    predictions = eval_pred.predictions
    labels = eval_pred.label_ids
    
    if isinstance(predictions, list):
        predictions = np.concatenate([p for p in predictions if p is not None], axis=0)
    elif isinstance(predictions, torch.Tensor):
        predictions = predictions.cpu().numpy()
    
    if isinstance(labels, list):
        labels = np.concatenate([l for l in labels if l is not None], axis=0)
    elif isinstance(labels, torch.Tensor):
        labels = labels.cpu().numpy()
    
    if len(predictions.shape) != 2:
        predictions = predictions.reshape(-1, NUM_LABELS)
    labels = labels.reshape(-1)
    
    preds = np.argmax(predictions, axis=1)
    accuracy = accuracy_score(labels, preds)
    precision_bin, recall_bin, f1_bin, _ = precision_recall_fscore_support(
        labels, preds, average="binary", zero_division=0
    )
    precision_per_cls, recall_per_cls, f1_per_cls, _ = precision_recall_fscore_support(
        labels, preds, average=None, zero_division=0
    )

    return {
        "accuracy": accuracy,
        "precision": precision_bin,
        "recall": recall_bin,
        "f1": f1_bin,
        "defective_precision": precision_per_cls[1],
        "defective_recall": recall_per_cls[1],
        "defective_f1": f1_per_cls[1],
        "non_defective_precision": precision_per_cls[0],
        "non_defective_recall": recall_per_cls[0],
        "non_defective_f1": f1_per_cls[0]
    }

def train_distillation():
    student_model = CodeBERTStudentModel(
        STUDENT_MODEL_PATH,
        teacher_hidden_size=TEACHER_HIDDEN_SIZE
    )

    training_args = TrainingArguments(
        output_dir=f"{OUTPUT_DIR_BASE}/distill-training",
        learning_rate=LEARNING_RATE,
        per_device_train_batch_size=BATCH_SIZE,
        per_device_eval_batch_size=4,
        num_train_epochs=NUM_EPOCHS,
        logging_dir=f"{OUTPUT_DIR_BASE}/distill-logs",
        logging_steps=10,
        eval_strategy="epoch",
        save_strategy="epoch",
        load_best_model_at_end=True,
        metric_for_best_model="defective_f1",
        greater_is_better=True,
        report_to="none",
        fp16=True,
        fp16_full_eval=False,
        remove_unused_columns=False,
        warmup_steps=0,
        lr_scheduler_type="linear",
        seed=FIXED_SEED,
        max_grad_norm=1.0,
        save_total_limit=MAX_CHECKPOINTS,
        gradient_checkpointing=True,
        dataloader_num_workers=0,
        dataloader_pin_memory=False,
    )
    class DistillTrainer(Trainer):
        def compute_loss(self, model, inputs, return_outputs=False, num_items_in_batch=None):
            outputs = model(** inputs)
            loss = outputs["loss"]
            return (loss, outputs) if return_outputs else loss

        def prediction_step(
            self,
            model,
            inputs,
            prediction_loss_only: bool,
            ignore_keys = None,
        ):
            student_inputs = {k: v for k, v in inputs.items() if not k.startswith("teacher_")}
            with torch.no_grad():
                outputs = model(** student_inputs)
            
            loss = outputs["loss"].detach() if outputs["loss"] is not None else None
            logits = outputs["logits"].detach()
            labels = inputs.get("labels").detach() if "labels" in inputs else None

            if prediction_loss_only:
                return (loss, None, None)
            else:
                return (loss, logits, labels)
        
        def _prepare_optimizer_and_scheduler(self, num_training_steps: int):
            super()._prepare_optimizer_and_scheduler(num_training_steps)
            if hasattr(self, 'scaler') and self.scaler is not None:
                self.scaler = None

    trainer = DistillTrainer(
        model=student_model,
        args=training_args,
        train_dataset=tokenized_train,
        eval_dataset=tokenized_val,
        data_collator=data_collator,
        compute_metrics=compute_metrics,
    )

    trainer.train()

    best_model_dir = f"{OUTPUT_DIR_BASE}/best-student-model"
    trainer.save_model(best_model_dir)
    student_tokenizer.save_pretrained(best_model_dir)

    test_results = trainer.evaluate(eval_dataset=tokenized_test)

    with open(f"{OUTPUT_DIR_BASE}/student_test_results.txt", "w") as f:
        for key, value in test_results.items():
            f.write(f"{key}: {value:.4f}\n" if isinstance(value, float) else f"{key}: {value}\n")

if __name__ == "__main__":
    os.makedirs(OUTPUT_DIR_BASE, exist_ok=True)
    train_distillation()
    
    import_utils.check_torch_load_is_safe = original_check
    modeling_utils.check_torch_load_is_safe = original_load_check
